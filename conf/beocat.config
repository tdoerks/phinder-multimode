/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    tdoerks/phinder — Beocat HPC profile (Kansas State University)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    https://www.k-state.edu/hpc/
    Launch with:  -profile beocat
    Override the QOS/extra sbatch flags with:  --clusterOptions '<flags>'
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Beocat'
    config_profile_description  = 'Kansas State University Beocat HPC cluster'
    config_profile_url          = 'https://www.k-state.edu/hpc/'
    // Extra sbatch flags injected per job; killable QOS by default, override with --clusterOptions
    clusterOptions              = '--gres=killable:0'
}

singularity {
    enabled    = true
    autoMounts = true
}

process {
    executor = 'slurm'
    queue    = 'batch.q'
    // Caps every process to Beocat node limits — e.g. clamps the 200GB process_high_memory label to 100GB.
    resourceLimits = [ cpus: 32, memory: 100.GB, time: 1.d ]
    clusterOptions = { params.clusterOptions ?: '' }
}

// Submission throttling for very large runs (thousands of samples) — prevents sbatch flooding /
// "Unexpected message received" errors under queue pressure.
executor {
    queueSize         = 100              // max jobs queued at once
    submitRateLimit   = '10/1min'        // max 10 submissions per minute
    pollInterval      = '45 sec'         // job-status poll cadence
    queueStatInterval = '10 min'         // queue-stats refresh
    exitReadTimeout   = '120 sec'        // wait for exit status on a finished job
}
