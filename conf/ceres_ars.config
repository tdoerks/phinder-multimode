/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    tdoerks/phinder — Ceres (USDA ARS SCInet) house profile overlay
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Named `ceres_ars` (NOT `ceres`) on purpose: nf-core/configs ships an official
    auto-loading `ceres` profile; a second profile named `ceres` would silently merge
    with it. This overlay keeps the house params.slurm_account convention.
    Launch with: -profile ceres_ars --slurm_account <grp>
----------------------------------------------------------------------------------------
*/

params {
    config_profile_description = 'Ceres - USDA ARS SCInet (house overlay)'
    config_profile_contact     = 'tdoerks'
}

apptainer {
    enabled     = true
    ociAutoPull = true
}

process {
    executor       = 'slurm'
    // Inject the SLURM account; fail early if it wasn't supplied.
    clusterOptions = {
        if (!params.slurm_account)
            throw new IllegalArgumentException("ERROR: --slurm_account is required on Ceres (-profile ceres_ars)")
        "-A ${params.slurm_account}"
    }
    // No `queue =` line — short/medium/long partitions are retired; default to the live `ceres` partition.
    errorStrategy  = { sleep(200); return 'retry' }
    maxRetries     = 2
}
